# Soulplace Help Desk – copy to .env and fill in your values.
# For Vercel: use Project → Settings → Environment Variables (same names).

# --- App (optional; defaults exist) ---
# SOULPLACE_SECRET_KEY=your-secret-key-change-in-production
# SOULPLACE_URL_PREFIX=/soulplace
# SOULPLACE_PUBLIC_URL=https://your-app.vercel.app
# SOULPLACE_API_TOKEN=
# SOULPLACE_PENDING_MAX_AGE_MINUTES=120

# --- Gmail / Email ---
SOULPLACE_SMTP_HOST=smtp.gmail.com
SOULPLACE_SMTP_PORT=587
SOULPLACE_SMTP_USER=your@gmail.com
SOULPLACE_SMTP_PASSWORD=your-app-password
SOULPLACE_EMAIL_FROM=your@gmail.com
SOULPLACE_EMAIL_TO=alerts@gmail.com
SOULPLACE_SMTP_TLS=1

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your-bot-token-from-BotFather
TELEGRAM_CHAT_ID=your-chat-id

# --- SMS (TextBelt free) ---
SOULPLACE_SMS_TO=919876543210

# --- WhatsApp: use ONE of these (all free) ---
# Option A – CallMeBot: https://www.callmebot.com/blog/free-api-whatsapp-messages/
# CALLMEBOT_WHATSAPP_PHONE=919876543210
# CALLMEBOT_WHATSAPP_APIKEY=your-callmebot-apikey
# Option B – WA Bridge: https://wabridge.cloud
# WABRIDGE_API_KEY=your-wabridge-api-key
# Option C – Green API (free Developer plan, 3 chats): https://console.green-api.com
SOULPLACE_WHATSAPP_TO=919876543210
GREEN_API_ID_INSTANCE=your-id-from-console
GREEN_API_TOKEN=your-token-from-console
